{
  "name": "tablemind",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-assisted tabletop session engine foundation.",
  "scripts": {
    "test": "node scripts/run-tests.mjs packages apps tests",
    "acceptance": "node scripts/run-tests.mjs tests/acceptance",
    "lint": "node scripts/check-js.mjs",
    "typecheck": "node scripts/check-js.mjs",
    "check": "node scripts/check-js.mjs",
    "build": "node scripts/check-js.mjs && node scripts/run-tests.mjs packages apps tests && node scripts/run-tests.mjs tests/acceptance"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  }
}
